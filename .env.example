# =============================================================
#  Variables de entorno - M&M Studio TFG ASIR
#
#  INSTRUCCIONES:
#  1. Copia este archivo: cp .env.example .env
#  2. Rellena los valores reales en .env
#  3. NUNCA subas el archivo .env a Git (está en .gitignore)
#
#  En producción real, la clave de Groq iría aquí en lugar de
#  estar hardcodeada en el JavaScript. En el TFG está en el JS
#  por simplicidad al ser una demo estática sin backend.
# =============================================================

# Clave de la API de Groq (https://console.groq.com)
GROQ_API_KEY=tu_clave_aqui

# Contraseña del panel de Grafana
GRAFANA_ADMIN_PASSWORD=mmstudio123

# Puerto del servidor web
HTTP_PORT=8080
HTTPS_PORT=8443
